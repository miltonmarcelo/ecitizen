generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Role {
  CITIZEN
  STAFF
}

enum IssueStatus {
  CREATED
  UNDER_REVIEW
  IN_PROGRESS
  RESOLVED
  CLOSED
  CANCELLED
}

enum IssueEventType {
  CREATED
  STATUS_CHANGED
  NOTE_ADDED
  INFO_REQUESTED
  INFO_RECEIVED
  ASSIGNED
  UNASSIGNED
  REOPENED
}

model User {
  id          Int      @id @default(autoincrement())
  firebaseUid String?
  email       String   @unique
  fullName    String
  role        Role
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  staffProfile Staff?
  issues       Issue[]        @relation("CitizenIssues")
  historyItems IssueHistory[] @relation("HistoryChangedByUser")
}

model Staff {
  id        Int      @id @default(autoincrement())
  userId    Int      @unique
  jobTitle  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user           User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignedIssues Issue[]
  notes          Note[]
}

model Issue {
  id           Int         @id @default(autoincrement())
  caseId       String      @unique
  title        String
  description  String
  categoryId   Int?
  addressLine1 String
  addressLine2 String?
  town         String?
  city         String
  county       String
  latitude     Float?
  longitude    Float?
  status       IssueStatus @default(CREATED)
  citizenId    Int
  staffId      Int?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  citizen User           @relation("CitizenIssues", fields: [citizenId], references: [id], onDelete: Cascade)
  category   Category? @relation(fields: [categoryId], references: [id])
  staff   Staff?         @relation(fields: [staffId], references: [id])
  notes   Note[]
  history IssueHistory[]

  @@index([citizenId])
  @@index([staffId])
  @@index([status])
  @@index([categoryId])
  @@index([createdAt])
}

model IssueHistory {
  id              Int            @id @default(autoincrement())
  issueId         Int
  eventType       IssueEventType
  fromStatus      IssueStatus?
  toStatus        IssueStatus?
  comment         String?
  changedByUserId Int
  changedAt       DateTime       @default(now())

  issue         Issue @relation(fields: [issueId], references: [id], onDelete: Cascade)
  changedByUser User  @relation("HistoryChangedByUser", fields: [changedByUserId], references: [id])

  @@index([issueId])
  @@index([changedByUserId])
  @@index([eventType])
  @@index([changedAt])
}

model Note {
  id        Int      @id @default(autoincrement())
  content   String
  issueId   Int
  staffId   Int
  createdAt DateTime @default(now())

  issue Issue @relation(fields: [issueId], references: [id], onDelete: Cascade)
  staff Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([issueId])
  @@index([staffId])
}

model Category {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  issues      Issue[]
}